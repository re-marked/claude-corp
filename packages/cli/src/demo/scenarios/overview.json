{
  "name": "overview",
  "title": "Overview — the full Claude Corp loop",
  "description": "First chat → hire team → tasks → /afk → wake briefing",
  "durationSec": 240,
  "setup": {
    "corpName": "demo-overview",
    "theme": "corporate",
    "founderName": "Mark"
  },
  "events": [
    { "at": 500, "event": { "type": "wait", "ms": 500 } },

    { "at": 1000, "event": {
      "type": "user-message",
      "channel": "dm-ceo-mark",
      "content": "I want to build a SaaS landing page. Can you put a team together?"
    }},

    { "at": 2500, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Got it. A SaaS landing page needs a frontend lead, a designer, and a copywriter. Let me hire them."
    }},

    { "at": 12000, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Frontend Lead' --rank leader" },
      "result": "Hired Frontend Lead (leader)",
      "durationMs": 1500
    }},

    { "at": 14000, "event": {
      "type": "agent-appear",
      "id": "frontend-lead",
      "displayName": "Frontend Lead",
      "rank": "leader"
    }},

    { "at": 14500, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Designer' --rank worker" },
      "result": "Hired Designer (worker)",
      "durationMs": 1200
    }},

    { "at": 16000, "event": {
      "type": "agent-appear",
      "id": "designer",
      "displayName": "Designer",
      "rank": "worker"
    }},

    { "at": 16500, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Copywriter' --rank worker" },
      "result": "Hired Copywriter (worker)",
      "durationMs": 1200
    }},

    { "at": 18000, "event": {
      "type": "agent-appear",
      "id": "copywriter",
      "displayName": "Copywriter",
      "rank": "worker"
    }},

    { "at": 19000, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Team is ready. Frontend Lead will coordinate. I'll create the contract now with three tasks."
    }},

    { "at": 30000, "event": {
      "type": "task-create",
      "id": "swift-oak",
      "title": "Design landing page mockup",
      "assignedTo": "Designer",
      "priority": "high",
      "status": "pending"
    }},

    { "at": 30500, "event": {
      "type": "task-create",
      "id": "cool-bay",
      "title": "Write hero section copy",
      "assignedTo": "Copywriter",
      "priority": "normal",
      "status": "pending"
    }},

    { "at": 31000, "event": {
      "type": "task-create",
      "id": "brave-pine",
      "title": "Implement landing page",
      "assignedTo": "Frontend Lead",
      "priority": "high",
      "status": "pending"
    }},

    { "at": 32000, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Tasks created. Designer starts first, copywriter in parallel, Frontend Lead waits for both."
    }},

    { "at": 42000, "event": {
      "type": "user-message",
      "channel": "dm-ceo-mark",
      "content": "Cool. I'm gonna grab dinner. /afk school-day"
    }},

    { "at": 43500, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Acknowledged. Going autonomous in school-day mode. Full delegation, no approval needed. See you in a few hours."
    }},

    { "at": 52000, "event": {
      "type": "slumber-start",
      "profile": "school-day",
      "durationMs": 25200000
    }},

    { "at": 53000, "event": { "type": "task-update", "id": "swift-oak", "status": "in_progress" }},
    { "at": 54000, "event": { "type": "task-update", "id": "cool-bay", "status": "in_progress" }},

    { "at": 55000, "event": {
      "type": "tool-call",
      "agent": "Designer",
      "channel": "dm-mark-designer",
      "tool": "write",
      "args": { "path": "designs/hero.fig" },
      "durationMs": 1500
    }},

    { "at": 57000, "event": {
      "type": "tool-call",
      "agent": "Copywriter",
      "channel": "dm-mark-copywriter",
      "tool": "write",
      "args": { "path": "copy/hero.md" },
      "durationMs": 1200
    }},

    { "at": 60000, "event": { "type": "task-update", "id": "swift-oak", "status": "completed" }},
    { "at": 61000, "event": { "type": "task-update", "id": "cool-bay", "status": "completed" }},
    { "at": 62000, "event": { "type": "task-update", "id": "brave-pine", "status": "in_progress" }},

    { "at": 63000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "read",
      "args": { "path": "designs/hero.fig" },
      "durationMs": 800
    }},

    { "at": 65000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "write",
      "args": { "path": "src/LandingPage.tsx" },
      "durationMs": 2000
    }},

    { "at": 68000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "bash",
      "args": { "command": "npm run build" },
      "result": "✓ Built in 4.2s",
      "durationMs": 1500
    }},

    { "at": 70500, "event": { "type": "task-update", "id": "brave-pine", "status": "completed" }},

    { "at": 80000, "event": { "type": "user-message", "channel": "dm-ceo-mark", "content": "/wake" }},

    { "at": 81000, "event": { "type": "slumber-end", "digest": "All tasks complete", "totalTicks": 24, "productiveTicks": 21 }},

    { "at": 82000, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Welcome back. 24 ticks, 21 productive. Designer shipped the mockup, Copywriter wrote the hero copy, Frontend Lead built the landing page and confirmed the build passes. All three contract tasks completed. Ready for your review."
    }}
  ]
}
