{
  "name": "overview",
  "title": "Overview — the full Claude Corp loop",
  "description": "Bootstrap → first chat → hire team → tasks → /afk → wake briefing",
  "durationSec": 180,
  "setup": {
    "corpName": "demo-overview",
    "theme": "corporate",
    "founderName": "Mark"
  },
  "events": [
    { "at": 800, "event": {
      "type": "user-message",
      "channel": "dm-ceo-mark",
      "content": "I want to build a SaaS landing page. Can you put a team together?"
    }},

    { "at": 2000, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Got it. A SaaS landing page needs three roles: a frontend lead to coordinate, a designer for the mockup, and a copywriter for the hero. Hiring now."
    }},

    { "at": 11000, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Frontend Lead' --rank leader" },
      "result": "Hired Frontend Lead",
      "durationMs": 1200
    }},

    { "at": 12500, "event": {
      "type": "agent-appear",
      "id": "frontend-lead",
      "displayName": "Frontend Lead",
      "rank": "leader"
    }},

    { "at": 13000, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Designer' --rank worker" },
      "result": "Hired Designer",
      "durationMs": 1000
    }},

    { "at": 14200, "event": {
      "type": "agent-appear",
      "id": "designer",
      "displayName": "Designer",
      "rank": "worker"
    }},

    { "at": 14700, "event": {
      "type": "tool-call",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "tool": "bash",
      "args": { "command": "cc-cli hire --name 'Copywriter' --rank worker" },
      "result": "Hired Copywriter",
      "durationMs": 1000
    }},

    { "at": 15900, "event": {
      "type": "agent-appear",
      "id": "copywriter",
      "displayName": "Copywriter",
      "rank": "worker"
    }},

    { "at": 16500, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Team's ready. Creating the contract with three tasks now."
    }},

    { "at": 22000, "event": {
      "type": "task-create",
      "id": "swift-oak",
      "title": "Design landing page mockup",
      "assignedTo": "Designer",
      "priority": "high",
      "status": "pending"
    }},
    { "at": 22300, "event": {
      "type": "task-create",
      "id": "cool-bay",
      "title": "Write hero section copy",
      "assignedTo": "Copywriter",
      "priority": "normal",
      "status": "pending"
    }},
    { "at": 22600, "event": {
      "type": "task-create",
      "id": "brave-pine",
      "title": "Implement landing page",
      "assignedTo": "Frontend Lead",
      "priority": "high",
      "status": "pending"
    }},

    { "at": 23500, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Designer and Copywriter start now in parallel. Frontend Lead waits for both, then ships the page."
    }},

    { "at": 32000, "event": {
      "type": "user-message",
      "channel": "dm-ceo-mark",
      "content": "Cool. I'm gonna grab dinner. /afk school-day"
    }},

    { "at": 33200, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Acknowledged. Going autonomous in school-day mode — full delegation, no approval needed. See you in a few hours."
    }},

    { "at": 41000, "event": { "type": "system-message", "channel": "dm-ceo-mark", "content": "🌑 SLUMBER active (school-day). CEO acknowledged. Agents are autonomous." }},
    { "at": 41500, "event": { "type": "slumber-start", "profile": "school-day", "durationMs": 25200000 }},

    { "at": 42500, "event": { "type": "task-update", "id": "swift-oak", "status": "in_progress" }},
    { "at": 43000, "event": { "type": "task-update", "id": "cool-bay", "status": "in_progress" }},

    { "at": 44000, "event": {
      "type": "tool-call",
      "agent": "Designer",
      "channel": "dm-mark-designer",
      "tool": "read",
      "args": { "path": "brand/colors.md" },
      "durationMs": 600
    }},
    { "at": 45000, "event": {
      "type": "tool-call",
      "agent": "Designer",
      "channel": "dm-mark-designer",
      "tool": "write",
      "args": { "path": "designs/hero.fig" },
      "durationMs": 1200
    }},

    { "at": 45500, "event": {
      "type": "tool-call",
      "agent": "Copywriter",
      "channel": "dm-mark-copywriter",
      "tool": "read",
      "args": { "path": "brand/voice.md" },
      "durationMs": 500
    }},
    { "at": 46500, "event": {
      "type": "tool-call",
      "agent": "Copywriter",
      "channel": "dm-mark-copywriter",
      "tool": "write",
      "args": { "path": "copy/hero.md" },
      "durationMs": 1000
    }},

    { "at": 48000, "event": { "type": "task-update", "id": "swift-oak", "status": "completed" }},
    { "at": 48500, "event": { "type": "task-update", "id": "cool-bay", "status": "completed" }},
    { "at": 49000, "event": { "type": "task-update", "id": "brave-pine", "status": "in_progress" }},

    { "at": 50000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "read",
      "args": { "path": "designs/hero.fig" },
      "durationMs": 600
    }},
    { "at": 51000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "read",
      "args": { "path": "copy/hero.md" },
      "durationMs": 500
    }},
    { "at": 52000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "write",
      "args": { "path": "src/LandingPage.tsx" },
      "durationMs": 1500
    }},
    { "at": 54000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "write",
      "args": { "path": "src/components/Hero.tsx" },
      "durationMs": 1200
    }},
    { "at": 56000, "event": {
      "type": "tool-call",
      "agent": "Frontend Lead",
      "channel": "dm-mark-frontend-lead",
      "tool": "bash",
      "args": { "command": "npm run build" },
      "result": "✓ Built in 4.2s",
      "durationMs": 1500
    }},

    { "at": 58000, "event": { "type": "task-update", "id": "brave-pine", "status": "completed" }},
    { "at": 58500, "event": { "type": "slumber-end", "digest": "All tasks complete", "totalTicks": 24, "productiveTicks": 21 }},

    { "at": 64000, "event": { "type": "user-message", "channel": "dm-ceo-mark", "content": "/wake" }},

    { "at": 65500, "event": {
      "type": "stream-end",
      "agent": "CEO",
      "channel": "dm-ceo-mark",
      "content": "Welcome back. 24 ticks, 21 productive. Designer shipped the mockup, Copywriter wrote the hero copy, Frontend Lead built the landing page and confirmed the build passes. All three contract tasks completed. Ready for your review."
    }}
  ]
}
